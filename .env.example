# ─── Base de Datos ───────────────────────────────────
# Para dev local: jdbc:postgresql://localhost:5432/parqueaderos
# Para produccion: usa el hostname del contenedor de la DB (ej. parqueadero-db-f3zhnv-db-1)
DB_URL=jdbc:postgresql://localhost:5432/parqueaderos
DB_USERNAME=postgres
DB_PASSWORD=change-me

# ─── API ─────────────────────────────────────────────
PORT=8080

# ─── JWT ─────────────────────────────────────────────
# Genera uno fuerte: openssl rand -base64 48
JWT_SECRET=change-me-generate-with-openssl-rand-base64-48
JWT_ACCESS_EXP=3600000
JWT_REFRESH_EXP=604800000

# ─── Resend Email ────────────────────────────────────
# Genera tu API key en https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=onboarding@resend.dev

# ─── PIN ─────────────────────────────────────────────
PIN_EXPIRATION=15
